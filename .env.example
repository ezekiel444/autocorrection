# Local Auto-Correction Tool Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

API_PORT=8080
API_KEY=changeme
MODEL_NAME=llama3.2:3b
MODEL_CONTEXT_WINDOW=4096

# LLM Backend: "openai" (Groq/cloud, fast) or "ollama" (local, private, slow)
LLM_BACKEND=openai

# Groq API (get key from https://console.groq.com/keys)
OPENAI_API_KEY=gsk_your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# Alternative: Google Gemini (get key from https://aistudio.google.com/api-keys)
# OPENAI_API_KEY=your_gemini_key
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_MODEL=gemini-2.0-flash-lite
